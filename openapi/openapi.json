{
  "openapi": "3.1.0",
  "info": {
    "title": "Data Monitor API",
    "description": "OpenAPI source of truth for Data Monitor backend routes.",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "Current deployment origin"
    }
  ],
  "tags": [
    { "name": "health" },
    { "name": "init" },
    { "name": "users" },
    { "name": "monitors" },
    { "name": "notifiers" },
    { "name": "scraper" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Bearer token used by user-scoped routes."
      }
    },
    "parameters": {
      "UserQuery": {
        "name": "user",
        "in": "query",
        "required": true,
        "schema": { "type": "integer", "minimum": 1 },
        "description": "Authorized user identifier."
      },
      "IdQuery": {
        "name": "id",
        "in": "query",
        "required": true,
        "schema": { "type": "integer", "minimum": 1 },
        "description": "Resource identifier."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        },
        "required": ["message"],
        "additionalProperties": true
      },
      "DeleteResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        },
        "required": ["message"],
        "additionalProperties": false
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "const": "ok" },
          "service": { "type": "string", "const": "data-monitor" },
          "timestamp": { "type": "string", "format": "date-time" },
          "uptimeSeconds": { "type": "integer", "minimum": 0 },
          "version": { "type": "string" }
        },
        "required": ["status", "service", "timestamp", "uptimeSeconds", "version"],
        "additionalProperties": false
      },
      "InitResponse": {
        "type": "object",
        "properties": {
          "init": { "type": "boolean" },
          "message": { "type": "string" }
        },
        "required": ["init", "message"],
        "additionalProperties": true
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "minimum": 1 },
          "email": { "type": "string", "format": "email" },
          "jwt": {
            "type": "string",
            "description": "Masked in responses as PRIVATE when stored."
          }
        },
        "required": ["id", "email", "jwt"],
        "additionalProperties": false
      },
      "CreateUserRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email" },
          "jwt": { "type": "string", "minLength": 1 }
        },
        "required": ["email", "jwt"],
        "additionalProperties": false
      },
      "UpdateUserRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email" },
          "jwt": {
            "type": "string",
            "description": "Use PRIVATE to preserve existing stored secret."
          }
        },
        "additionalProperties": false
      },
      "Monitor": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "minimum": 1 },
          "parent": { "type": "string", "maxLength": 256 },
          "enabled": { "type": "boolean" },
          "interval": { "type": "number" },
          "threshold": { "type": "number" },
          "condition": {
            "type": "string",
            "enum": ["<", "\u2264", ">", "\u2265"]
          },
          "notifierId": { "type": ["integer", "null"], "minimum": 1 },
          "userId": { "type": "integer", "minimum": 1 }
        },
        "required": ["id", "parent", "enabled", "interval", "threshold", "condition", "userId"],
        "additionalProperties": false
      },
      "CreateMonitorRequest": {
        "type": "object",
        "properties": {
          "parent": { "type": "string", "maxLength": 256 },
          "enabled": { "type": "boolean" },
          "interval": { "type": "number" },
          "threshold": { "type": "number" },
          "condition": {
            "type": "string",
            "enum": ["<", "\u2264", ">", "\u2265"]
          },
          "notifier": { "type": ["integer", "null"], "minimum": 1 },
          "user": { "type": "integer", "minimum": 1 }
        },
        "required": ["parent", "interval", "threshold", "condition", "user"],
        "additionalProperties": false
      },
      "UpdateMonitorRequest": {
        "type": "object",
        "properties": {
          "parent": { "type": "string", "maxLength": 256 },
          "enabled": { "type": "boolean" },
          "interval": { "type": "number" },
          "threshold": { "type": "number" },
          "condition": {
            "type": "string",
            "enum": ["<", "\u2264", ">", "\u2265"]
          },
          "notifier": { "type": ["integer", "null"], "minimum": 1 }
        },
        "additionalProperties": false
      },
      "Notifier": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "minimum": 1 },
          "type": { "type": "string", "enum": ["email", "discord"] },
          "origin": {
            "type": "string",
            "description": "Masked in responses as PRIVATE when stored."
          },
          "sender": { "type": "string", "maxLength": 256 },
          "password": {
            "type": "string",
            "description": "Masked in responses as PRIVATE when stored."
          },
          "userId": { "type": "integer", "minimum": 1 }
        },
        "required": ["id", "type", "origin", "sender", "password", "userId"],
        "additionalProperties": false
      },
      "CreateNotifierRequest": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["email", "discord"] },
          "origin": { "type": "string", "minLength": 1 },
          "sender": { "type": "string", "maxLength": 256 },
          "password": { "type": "string" },
          "user": { "type": "integer", "minimum": 1 }
        },
        "required": ["type", "origin", "sender", "user"],
        "additionalProperties": false
      },
      "UpdateNotifierRequest": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["email", "discord"] },
          "origin": { "type": "string" },
          "sender": { "type": "string", "maxLength": 256 },
          "password": { "type": "string" }
        },
        "additionalProperties": false
      },
      "NotifierNotifyRequest": {
        "type": "object",
        "description": "Notifier-specific notification payload.",
        "additionalProperties": true
      },
      "ScraperAuthRequest": {
        "type": "object",
        "description": "Pass-through payload to scraper auth endpoints.",
        "additionalProperties": true
      },
      "ScraperResponse": {
        "type": ["object", "array", "string", "number", "boolean", "null"],
        "description": "Pass-through response from scraper backend."
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Request validation or processing error.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "Missing or invalid authorization header.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Forbidden": {
        "description": "Authorization failed for provided user context.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "NotFound": {
        "description": "Requested resource does not exist.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "ServerError": {
        "description": "Unexpected server error.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    }
  },
  "paths": {
    "/api/health": {
      "get": {
        "tags": ["health"],
        "summary": "Service liveness probe",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Service is healthy.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" }
              }
            }
          }
        }
      },
      "head": {
        "tags": ["health"],
        "summary": "Health probe without body",
        "operationId": "headHealth",
        "responses": {
          "200": { "description": "Service is healthy." }
        }
      }
    },
    "/api/init": {
      "get": {
        "tags": ["init"],
        "summary": "Initialize database and feature metadata",
        "operationId": "initializeApplication",
        "responses": {
          "200": {
            "description": "Initialization completed.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/InitResponse" }
              }
            }
          },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/user": {
      "get": {
        "tags": ["users"],
        "summary": "List or filter users",
        "operationId": "getUsers",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1 }
          },
          {
            "name": "email",
            "in": "query",
            "schema": { "type": "string", "format": "email" }
          },
          {
            "name": "jwt",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Used only with indexed filters by current implementation."
          }
        ],
        "responses": {
          "200": {
            "description": "Users list.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/User" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      },
      "post": {
        "tags": ["users"],
        "summary": "Create user",
        "operationId": "createUser",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateUserRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created user.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      },
      "put": {
        "tags": ["users"],
        "summary": "Update user by id",
        "operationId": "updateUser",
        "parameters": [
          { "$ref": "#/components/parameters/IdQuery" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateUserRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated user.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      },
      "delete": {
        "tags": ["users"],
        "summary": "Delete user by id",
        "operationId": "deleteUser",
        "parameters": [
          { "$ref": "#/components/parameters/IdQuery" }
        ],
        "responses": {
          "200": {
            "description": "Delete summary.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DeleteResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/monitor": {
      "get": {
        "tags": ["monitors"],
        "summary": "List or filter monitors for authorized user",
        "operationId": "getMonitors",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/UserQuery" },
          {
            "name": "id",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1 }
          },
          {
            "name": "parent",
            "in": "query",
            "schema": { "type": "string", "maxLength": 256 }
          },
          {
            "name": "enabled",
            "in": "query",
            "schema": { "type": "boolean" }
          },
          {
            "name": "threshold",
            "in": "query",
            "schema": { "type": "number" }
          },
          {
            "name": "condition",
            "in": "query",
            "schema": { "type": "string", "enum": ["<", "\u2264", ">", "\u2265"] }
          },
          {
            "name": "notifier",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1 }
          },
          {
            "name": "interval",
            "in": "query",
            "schema": { "type": "number" }
          }
        ],
        "responses": {
          "200": {
            "description": "Monitors list.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Monitor" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "post": {
        "tags": ["monitors"],
        "summary": "Create monitor",
        "operationId": "createMonitor",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateMonitorRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created monitor.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Monitor" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "put": {
        "tags": ["monitors"],
        "summary": "Update monitor by id for authorized user",
        "operationId": "updateMonitor",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/IdQuery" },
          { "$ref": "#/components/parameters/UserQuery" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateMonitorRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated monitor.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Monitor" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["monitors"],
        "summary": "Delete monitor by id for authorized user",
        "operationId": "deleteMonitor",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/IdQuery" },
          { "$ref": "#/components/parameters/UserQuery" }
        ],
        "responses": {
          "200": {
            "description": "Delete summary.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DeleteResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/notifier": {
      "get": {
        "tags": ["notifiers"],
        "summary": "List or filter notifiers for authorized user",
        "operationId": "getNotifiers",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/UserQuery" },
          {
            "name": "id",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1 }
          },
          {
            "name": "type",
            "in": "query",
            "schema": { "type": "string", "enum": ["email", "discord"] }
          },
          {
            "name": "origin",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "sender",
            "in": "query",
            "schema": { "type": "string", "maxLength": 256 }
          },
          {
            "name": "password",
            "in": "query",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Notifiers list.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Notifier" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "post": {
        "tags": ["notifiers"],
        "summary": "Create notifier or send notifier test message",
        "description": "When type query parameter is present, this operation sends a notification instead of creating a notifier.",
        "operationId": "postNotifier",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "schema": { "type": "string", "enum": ["email", "discord"] },
            "description": "If provided, triggers notification send mode."
          },
          {
            "name": "user",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1 },
            "description": "Required in send mode."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  { "$ref": "#/components/schemas/CreateNotifierRequest" },
                  { "$ref": "#/components/schemas/NotifierNotifyRequest" }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created notifier or notifier send info.",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    { "$ref": "#/components/schemas/Notifier" },
                    {
                      "type": ["object", "string"],
                      "additionalProperties": true
                    }
                  ]
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      },
      "put": {
        "tags": ["notifiers"],
        "summary": "Update notifier by id for authorized user",
        "operationId": "updateNotifier",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/IdQuery" },
          { "$ref": "#/components/parameters/UserQuery" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateNotifierRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated notifier.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Notifier" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["notifiers"],
        "summary": "Delete notifier by id for authorized user",
        "operationId": "deleteNotifier",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/IdQuery" },
          { "$ref": "#/components/parameters/UserQuery" }
        ],
        "responses": {
          "200": {
            "description": "Delete summary.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DeleteResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/scraper/login": {
      "post": {
        "tags": ["scraper"],
        "summary": "Proxy login request to scraper service",
        "operationId": "scraperLogin",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ScraperAuthRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Scraper response payload.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ScraperResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/scraper/logout": {
      "post": {
        "tags": ["scraper"],
        "summary": "Proxy logout request to scraper service",
        "operationId": "scraperLogout",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ScraperAuthRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Scraper response payload.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ScraperResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/scraper/data": {
      "get": {
        "tags": ["scraper"],
        "summary": "Proxy full data payload from scraper service",
        "operationId": "getScraperData",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Scraper response payload.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ScraperResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/scraper/items": {
      "get": {
        "tags": ["scraper"],
        "summary": "Proxy item list payload from scraper service",
        "operationId": "getScraperItems",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Optional item name filter."
          }
        ],
        "responses": {
          "200": {
            "description": "Scraper response payload.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ScraperResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    }
  }
}
