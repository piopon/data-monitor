{
  "post": {
    "tags": [
      "scraper"
    ],
    "summary": "Proxy logout request to scraper service",
    "operationId": "scraperLogout",
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "$ref": "#/components/schemas/ScraperAuthRequest"
          }
        }
      }
    },
    "responses": {
      "200": {
        "description": "Scraper response payload.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ScraperResponse"
            }
          }
        }
      },
      "400": {
        "$ref": "#/components/responses/BadRequest"
      },
      "500": {
        "$ref": "#/components/responses/ServerError"
      }
    }
  }
}
